{
  "name": "@actor-bonilla/http",
  "version": "1.0.0",
  "description": "HTTP client built on native fetch, composable with Actor Bonilla core",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nowayhecodes/actor-bonilla.git"
  },
  "bugs": {
    "url": "https://github.com/nowayhecodes/actor-bonilla/issues"
  },
  "homepage": "https://github.com/nowayhecodes/actor-bonilla/tree/main/packages/http/README.md",
  "scripts": {
    "build": "tsc",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --config jest.config.cjs",
    "release": "semantic-release"
  },
  "keywords": [
    "http",
    "fetch",
    "actor",
    "bonilla",
    "typescript"
  ],
  "author": "Gustavo Cavalcante <nowayhecodes@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@actor-bonilla/core": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.2",
    "cross-env": "10.1.0",
    "jest": "30.4.2",
    "semantic-release": "25.0.3",
    "typia": "12.1.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.5.0",
  "release": {
    "branches": [
      {
        "name": "main"
      }
    ],
    "tagFormat": "@actor-bonilla/http@${version}",
    "repositoryUrl": "https://github.com/nowayhecodes/actor-bonilla",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": ["CHANGELOG.md", "package.json"],
          "message": "chore(release): @actor-bonilla/http ${nextRelease.version}\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
