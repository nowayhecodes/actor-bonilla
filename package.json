{
  "name": "actor-bonilla",
  "version": "1.0.0",
  "description": "High-performance actor system for TypeScript",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nowayhecodes/actor-bonilla.git"
  },
  "bugs": {
    "url": "https://github.com/nowayhecodes/actor-bonilla/issues"
  },
  "homepage": "https://github.com/nowayhecodes/actor-bonilla#readme",
  "scripts": {
    "prepare": "ts-patch install",
    "run": "tsx src/index.ts",
    "build": "tsc",
    "prettier": "prettier --write src/**/*.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "demo": "tsx examples/demo.ts",
    "bench": "tsx src/benchmark.ts"
  },
  "keywords": [
    "actor model",
    "bonilla",
    "typescript",
    "ts",
    "actor system",
    "concurrency",
    "parallelism"
  ],
  "author": "Gustavo Cavalcante <nowayhecodes@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.2",
    "jest": "30.4.2",
    "prettier": "3.8.3",
    "ts-jest": "^29.4.9",
    "ts-patch": "^4.0.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@swc/core": "1.15.33",
    "typia": "^12.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.5.0"
}
