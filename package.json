{
  "name": "actor-bonilla-repo",
  "private": true,
  "description": "Monorepo for @actor-bonilla/core and @actor-bonilla/http",
  "scripts": {
    "prepare": "pnpm exec ts-patch install",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm --filter @actor-bonilla/core run test:coverage",
    "demo": "pnpm --filter @actor-bonilla/core run demo",
    "bench": "pnpm --filter @actor-bonilla/core run bench",
    "prettier": "pnpm --filter @actor-bonilla/core run prettier"
  },
  "keywords": [],
  "author": "Gustavo Cavalcante <nowayhecodes@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.5.0",
  "devDependencies": {
    "ts-patch": "4.0.1",
    "typescript": "6.0.3"
  }
}
