{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node"],
    "plugins": [{ "transform": "typia/lib/transform" }]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test", "examples"]
}
